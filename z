#!/usr/bin/env bash
set -euo pipefail

APP_NAME="еӢӨрҹ’©зҡҮе·Ҙе…·з®ұ"
APP_CMD="z"
APP_VER="0.1.0"

C_RESET='\033[0m'; C_CYAN='\033[96m'; C_GREEN='\033[32m'; C_YELLOW='\033[33m'; C_RED='\033[31m'

pause(){ read -r -p "жҢүеӣһиҪҰз»§з»ӯ..." _; }

have_cmd(){ command -v "$1" >/dev/null 2>&1; }

install_local(){
  echo -e "${C_YELLOW}ејҖе§Ӣе®үиЈ…еҲ°жң¬жңәпјҲ/usr/local/bin/zпјү...${C_RESET}"
  local tmp
  tmp="$(mktemp)"

  if ! curl -fsSL "https://z.dfgr.eu.org/u?ts=$(date +%s)" -o "$tmp"; then
    echo -e "${C_RED}дёӢиҪҪеӨұиҙҘпјҢиҜ·жЈҖжҹҘзҪ‘з»ңеҗҺйҮҚиҜ•${C_RESET}"
    rm -f "$tmp"
    return 1
  fi

  if [[ "$EUID" -eq 0 ]]; then
    install -m 0755 "$tmp" /usr/local/bin/z
  else
    sudo install -m 0755 "$tmp" /usr/local/bin/z
  fi

  rm -f "$tmp"
  echo -e "${C_GREEN}вң… е®үиЈ…е®ҢжҲҗпјҡзҺ°еңЁеҸҜзӣҙжҺҘиҫ“е…Ҙ z еҗҜеҠЁ${C_RESET}"
}

first_run_install_prompt(){
  # иӢҘзі»з»ҹйҮҢиҝҳжІЎжңүеҸҜжү§иЎҢе‘Ҫд»Ө zпјҢеҲҷеңЁйҰ–ж¬Ўжү§иЎҢж—¶жҸҗзӨәе®үиЈ…
  if ! command -v z >/dev/null 2>&1; then
    echo -e "${C_YELLOW}жЈҖжөӢеҲ°дҪ иҝҳжңӘе®үиЈ…е‘Ҫд»Ө zгҖӮ${C_RESET}"
    read -r -p "жҳҜеҗҰзҺ°еңЁе®үиЈ…еҲ° /usr/local/bin/zпјҹ[Y/n]: " ans
    case "${ans:-Y}" in
      n|N) ;;
      *) install_local || true ;;
    esac
    pause
  fi
}

update_script(){
  echo -e "${C_YELLOW}ејҖе§Ӣжӣҙж–°и„ҡжң¬...${C_RESET}"
  local tmp
  tmp="$(mktemp)"
  if ! curl -fsSL "https://z.dfgr.eu.org/u?ts=$(date +%s)" -o "$tmp"; then
    echo -e "${C_RED}дёӢиҪҪеӨұиҙҘпјҢиҜ·зЁҚеҗҺйҮҚиҜ•${C_RESET}"
    rm -f "$tmp"
    return 1
  fi

  if [[ "$EUID" -eq 0 ]]; then
    install -m 0755 "$tmp" /usr/local/bin/z
  else
    sudo install -m 0755 "$tmp" /usr/local/bin/z
  fi

  rm -f "$tmp"
  echo -e "${C_GREEN}вң… жӣҙж–°е®ҢжҲҗпјҢйҮҚж–°жү§иЎҢ z еҚіеҸҜ${C_RESET}"
}

os_family(){
  if [[ -f /etc/os-release ]]; then
    . /etc/os-release
    case "${ID_LIKE:-$ID}" in
      *debian*|*ubuntu*) echo debian ;;
      *rhel*|*fedora*|*centos*|*rocky*|*almalinux*) echo rhel ;;
      *) echo unknown ;;
    esac
  else
    echo unknown
  fi
}

pm_update(){
  case "$(os_family)" in
    debian) sudo apt-get update -y && sudo DEBIAN_FRONTEND=noninteractive apt-get upgrade -y ;;
    rhel) if have_cmd dnf; then sudo dnf -y upgrade; else sudo yum -y update; fi ;;
    *) echo -e "${C_RED}дёҚж”ҜжҢҒзҡ„зі»з»ҹ${C_RESET}"; return 1 ;;
  esac
}

show_system_info(){
  echo -e "${C_CYAN}===== зі»з»ҹдҝЎжҒҜ =====${C_RESET}"
  echo "дё»жңәеҗҚ: $(hostname)"
  echo "еҶ…ж ё: $(uname -r)"
  if [[ -f /etc/os-release ]]; then
    . /etc/os-release
    echo "зі»з»ҹ: ${PRETTY_NAME:-$ID}"
  fi
  echo "жһ¶жһ„: $(uname -m)"
  echo "еңЁзәҝж—¶й•ҝ: $(uptime -p || true)"
  echo "CPU: $(lscpu 2>/dev/null | awk -F: '/Model name/{gsub(/^ +/,"",$2);print $2; exit}' || echo N/A)"
  echo "еҶ…еӯҳ: $(free -h | awk '/Mem:/{print $3"/"$2}')"
  echo "зЈҒзӣҳ:"
  df -hT | sed -n '1,8p'
  echo
  if have_cmd curl; then
    echo "е…¬зҪ‘IP: $(curl -s --max-time 3 https://api.ipify.org || echo N/A)"
  fi
}

ensure_docker(){
  if have_cmd docker; then
    echo -e "${C_GREEN}Docker е·Іе®үиЈ…${C_RESET}"; return 0
  fi
  echo -e "${C_YELLOW}жңӘжЈҖжөӢеҲ° DockerпјҢејҖе§Ӣе®үиЈ…...${C_RESET}"
  case "$(os_family)" in
    debian)
      sudo apt-get update -y
      sudo apt-get install -y ca-certificates curl gnupg
      sudo install -m 0755 -d /etc/apt/keyrings
      curl -fsSL https://download.docker.com/linux/$(. /etc/os-release; echo "$ID")/gpg | sudo gpg --dearmor -o /etc/apt/keyrings/docker.gpg
      sudo chmod a+r /etc/apt/keyrings/docker.gpg
      echo \
"deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/$(. /etc/os-release; echo "$ID") \
$(. /etc/os-release; echo "$VERSION_CODENAME") stable" | sudo tee /etc/apt/sources.list.d/docker.list >/dev/null
      sudo apt-get update -y
      sudo apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
      ;;
    rhel)
      if have_cmd dnf; then
        sudo dnf -y install dnf-plugins-core
        sudo dnf config-manager --add-repo https://download.docker.com/linux/centos/docker-ce.repo || true
        sudo dnf -y install docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
      else
        sudo yum -y install yum-utils
        sudo yum-config-manager --add-repo https://download.docker.com/linux/centos/docker-ce.repo || true
        sudo yum -y install docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
      fi
      ;;
    *) echo -e "${C_RED}дёҚж”ҜжҢҒзҡ„зі»з»ҹ${C_RESET}"; return 1 ;;
  esac
  sudo systemctl enable --now docker
  sudo usermod -aG docker "$USER" || true
  echo -e "${C_GREEN}Docker е®үиЈ…е®ҢжҲҗпјҲйҮҚж–°зҷ»еҪ•еҗҺеҸҜе…Қ sudoпјү${C_RESET}"
}

docker_status(){
  if ! have_cmd docker; then echo "Docker жңӘе®үиЈ…"; return; fi
  echo "Docker: $(docker -v)"
  docker compose version || true
  echo
  echo "е®№еҷЁж•°йҮҸ: $(docker ps -a -q 2>/dev/null | wc -l)"
  echo "й•ңеғҸж•°йҮҸ: $(docker images -q 2>/dev/null | wc -l)"
  echo "зҪ‘з»ңж•°йҮҸ: $(docker network ls -q 2>/dev/null | wc -l)"
  echo "еҚ·ж•°йҮҸ: $(docker volume ls -q 2>/dev/null | wc -l)"
  echo
  docker ps -a --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'
}

docker_menu(){
  while true; do
    clear
    echo -e "${C_CYAN}${APP_NAME} - Dockerз®ЎзҗҶ${C_RESET}"
    echo "1) е®үиЈ…/жӣҙж–° Docker"
    echo "2) жҹҘзңӢ Docker е…ЁеұҖзҠ¶жҖҒ"
    echo "3) еҲ—еҮәе®№еҷЁ"
    echo "4) жҹҘзңӢе®№еҷЁж—Ҙеҝ—"
    echo "5) йҮҚеҗҜе®№еҷЁ"
    echo "6) еҗҜеҒңе®№еҷЁ"
    echo "0) иҝ”еӣһдё»иҸңеҚ•"
    read -r -p "иҜ·йҖүжӢ©: " c
    case "$c" in
      1) ensure_docker; pause ;;
      2) docker_status; pause ;;
      3) docker ps -a; pause ;;
      4) read -r -p "е®№еҷЁеҗҚ: " n; docker logs --tail 200 "$n"; pause ;;
      5) read -r -p "е®№еҷЁеҗҚ: " n; docker restart "$n"; pause ;;
      6) read -r -p "е®№еҷЁеҗҚ: " n; read -r -p "start/stop: " a; docker "$a" "$n"; pause ;;
      0) break ;;
      *) echo "ж— ж•Ҳиҫ“е…Ҙ"; pause ;;
    esac
  done
}

main(){
  while true; do
    clear
    echo -e "${C_CYAN}в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—${C_RESET}"
    echo -e "${C_CYAN}в•‘  ${APP_NAME} v${APP_VER} (${APP_CMD})${C_CYAN}            в•‘${C_RESET}"
    echo -e "${C_CYAN}в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ${C_RESET}"
    echo "99) е®үиЈ…еҲ°жң¬жңәпјҲz е‘Ҫд»Өпјү"
    echo "00) и„ҡжң¬жӣҙж–°"
    echo "1) зі»з»ҹдҝЎжҒҜжҹҘиҜў"
    echo "2) зі»з»ҹжӣҙж–°"
    echo "6) Dockerз®ЎзҗҶ"
    echo "0) йҖҖеҮә"
    read -r -p "иҜ·иҫ“е…ҘдҪ зҡ„йҖүжӢ©: " choice
    case "$choice" in
      99) install_local; pause ;;
      00) update_script; pause ;;
      1) show_system_info; pause ;;
      2) pm_update; pause ;;
      6) docker_menu ;;
      0) exit 0 ;;
      *) echo "ж— ж•Ҳиҫ“е…Ҙ"; pause ;;
    esac
  done
}

first_run_install_prompt
main "$@"
