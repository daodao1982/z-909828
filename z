ensure_nginx_market(){
  ensure_docker
  sudo mkdir -p /home/web/conf.d /home/web/html
  if ! docker ps -a --format '{{.Names}}' | grep -qx nginx; then
    docker run -d --name nginx --restart always -p 80:80 \
      -v /home/web/conf.d:/etc/nginx/conf.d \
      -v /home/web/html:/usr/share/nginx/html \
      nginx:alpine
  else
    docker start nginx >/dev/null 2>&1 || true
  fi
}

run_k_app(){
  local app_id="$1"
  if have_cmd k; then
    k app "$app_id"
    return
  fi

  echo -e "${C_YELLOW}未检测到 k，尝试临时拉取并执行...${C_RESET}"
  local ktmp
  ktmp="$(mktemp)"
  if ! curl -fsSL https://kejilion.sh -o "$ktmp"; then
    echo -e "${C_RED}拉取失败，请先安装 k 再重试${C_RESET}"
    rm -f "$ktmp"
    return 1
  fi
  chmod +x "$ktmp"
  bash "$ktmp" app "$app_id"
  rm -f "$ktmp"
}

install_openclaw_quick(){
  echo -e "${C_YELLOW}开始一键安装 OpenClaw...${C_RESET}"

  if ! have_cmd node || ! have_cmd npm; then
    echo -e "${C_YELLOW}未检测到 Node.js/npm，先自动安装 Node.js 24...${C_RESET}"
    case "$(os_family)" in
      debian)
        curl -fsSL https://deb.nodesource.com/setup_24.x | sudo bash -
        sudo apt-get update -y
        sudo DEBIAN_FRONTEND=noninteractive apt-get install -y nodejs build-essential python3 libatomic1
        ;;
      rhel)
        curl -fsSL https://rpm.nodesource.com/setup_24.x | sudo bash -
        if have_cmd dnf; then
          sudo dnf -y install nodejs gcc-c++ make python3 libatomic
        else
          sudo yum -y install nodejs gcc-c++ make python3 libatomic
        fi
        ;;
      *)
        echo -e "${C_RED}不支持的系统，请先手动安装 Node.js 后重试${C_RESET}"
        return 1
        ;;
    esac
  fi

  if [[ "${EUID}" -eq 0 ]]; then
    npm install -g openclaw@latest
  else
    sudo npm install -g openclaw@latest
  fi

  openclaw onboard --install-daemon
  sed -i 's|"profile": "messaging"|"profile": "full"|g' ~/.openclaw/openclaw.json 2>/dev/null || true
  openclaw gateway restart || true

  echo -e "${C_GREEN}✅ OpenClaw 安装完成${C_RESET}"
  echo "常用命令："
  echo "  openclaw status"
  echo "  openclaw gateway status"
}

