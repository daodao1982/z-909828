#!/usr/bin/env bash
set -euo pipefail

APP_NAME="勤💩皇工具箱"
APP_CMD="z"
APP_VER="0.1.0"

C_RESET='\033[0m'; C_CYAN='\033[96m'; C_GREEN='\033[32m'; C_YELLOW='\033[33m'; C_RED='\033[31m'

pause(){ read -r -p "按回车继续..." _; }

have_cmd(){ command -v "$1" >/dev/null 2>&1; }

update_script(){
  echo -e "${C_YELLOW}开始更新脚本...${C_RESET}"
  local tmp
  tmp="$(mktemp)"
  if ! curl -fsSL "https://z.dfgr.eu.org/u?ts=$(date +%s)" -o "$tmp"; then
    echo -e "${C_RED}下载失败，请稍后重试${C_RESET}"
    rm -f "$tmp"
    return 1
  fi

  if [[ "$EUID" -eq 0 ]]; then
    install -m 0755 "$tmp" /usr/local/bin/z
  else
    sudo install -m 0755 "$tmp" /usr/local/bin/z
  fi

  rm -f "$tmp"
  echo -e "${C_GREEN}✅ 更新完成，重新执行 z 即可${C_RESET}"
}

os_family(){
  if [[ -f /etc/os-release ]]; then
    . /etc/os-release
    case "${ID_LIKE:-$ID}" in
      *debian*|*ubuntu*) echo debian ;;
      *rhel*|*fedora*|*centos*|*rocky*|*almalinux*) echo rhel ;;
      *) echo unknown ;;
    esac
  else
    echo unknown
  fi
}

pm_update(){
  case "$(os_family)" in
    debian) sudo apt-get update -y && sudo DEBIAN_FRONTEND=noninteractive apt-get upgrade -y ;;
    rhel) if have_cmd dnf; then sudo dnf -y upgrade; else sudo yum -y update; fi ;;
    *) echo -e "${C_RED}不支持的系统${C_RESET}"; return 1 ;;
  esac
}

show_system_info(){
  echo -e "${C_CYAN}===== 系统信息 =====${C_RESET}"
  echo "主机名: $(hostname)"
  echo "内核: $(uname -r)"
  if [[ -f /etc/os-release ]]; then
    . /etc/os-release
    echo "系统: ${PRETTY_NAME:-$ID}"
  fi
  echo "架构: $(uname -m)"
  echo "在线时长: $(uptime -p || true)"
  echo "CPU: $(lscpu 2>/dev/null | awk -F: '/Model name/{gsub(/^ +/,"",$2);print $2; exit}' || echo N/A)"
  echo "内存: $(free -h | awk '/Mem:/{print $3"/"$2}')"
  echo "磁盘:"
  df -hT | sed -n '1,8p'
  echo
  if have_cmd curl; then
    echo "公网IP: $(curl -s --max-time 3 https://api.ipify.org || echo N/A)"
  fi
}

install_pkgs(){
  case "$(os_family)" in
    debian)
      sudo apt-get update -y
      sudo DEBIAN_FRONTEND=noninteractive apt-get install -y "$@"
      ;;
    rhel)
      if have_cmd dnf; then
        sudo dnf -y install "$@"
      else
        sudo yum -y install "$@"
      fi
      ;;
    *)
      echo -e "${C_RED}不支持的系统${C_RESET}"
      return 1
      ;;
  esac
}

tools_status_line(){
  local n="$1"
  if have_cmd "$n"; then
    printf "✅ %-12s 已安装" "$n"
  else
    printf "❌ %-12s 未安装" "$n"
  fi
}

